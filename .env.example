# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose to frontend

# ─── TextBelt SMS ────────────────────────────────────────────────────────────
TEXTBELT_API_KEY=textbelt                              # "textbelt" = free 1/day; use paid key in prod

# ─── Twilio SMS (not wired up yet — reserved for when you set up an account) ──
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Vapi ────────────────────────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key_here                   # Vapi dashboard → API Keys (for setup script)
VAPI_WEBHOOK_SECRET=your_random_webhook_secret_here   # shared secret for all Vapi tool endpoints

# ─── Platform ────────────────────────────────────────────────────────────────
VERCEL_DOMAIN=your-app.vercel.app                     # no https://
JWT_SECRET=your_random_jwt_secret_here
CRON_SECRET=your_random_cron_secret_here

# ─── Auth ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your_platform_admin_password           # logs in as admin (sees all clients)
# Client passwords live in clients.dashboard_password (Supabase) — not env vars

# ─── Google Calendar (bookAppointment tool) ─────────────────────────────────────
# Paste the FULL contents of a Google service-account JSON key as one value.
# Share the target calendar with the service account's client_email
# ("Make changes to events") and set clients.calendar_id (see sql/007_*.sql).
# GOOGLE_SERVICE_ACCOUNT_JSON is also accepted (same value) if you're reusing
# the credentials from another project that uses that name.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── Deprecated (moved to clients table) ────────────────────────────────────
# VAPI_AGENT_ID         → clients.agent_id
# DOCTOR_EMERGENCY_PHONE → clients.doctor_phone
# FRONT_DESK_PHONE       → clients.front_desk_phone
# DASHBOARD_PASSWORD     → clients.dashboard_password
# TIMEZONE               → clients.timezone
