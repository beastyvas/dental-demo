# ══════════════════════════════════════════════════════════
#  Hammond Dental AI Receptionist — Environment Variables
#  Copy this file to .env.local for local dev.
#  Set all of these in Vercel → Project → Settings → Environment Variables.
# ══════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # "service_role" key — NEVER expose to frontend

# ─── Twilio ────────────────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+17025550000         # Your Twilio phone number (E.164 format)

# ─── Staff phone numbers ───────────────────────────────────────────────────────
DOCTOR_EMERGENCY_PHONE=+17025550001    # Receives 🚨 emergency SMS (Feature 2)
FRONT_DESK_PHONE=+17025550002          # Receives morning summary at 8am (Feature 3)

# ─── Vapi ──────────────────────────────────────────────────────────────────────
# Shared secret between Vapi tool calls and your webhook endpoints.
# Generate any random string, e.g.: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=your_random_secret_here

# ─── Dashboard auth (Feature 5) ────────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_strong_password_here
JWT_SECRET=another_random_secret_for_jwt_signing    # openssl rand -hex 32

# ─── Vercel Cron (Feature 3) ───────────────────────────────────────────────────
# Vercel auto-sets CRON_SECRET in production. For local testing of the cron
# endpoint, set it manually to any string and pass it as the Authorization header.
CRON_SECRET=vercel_sets_this_automatically_in_prod

# ─── Timezone (Las Vegas) ──────────────────────────────────────────────────────
# Default is America/Los_Angeles. Only change if you repurpose this for
# a different timezone.
TIMEZONE=America/Los_Angeles
