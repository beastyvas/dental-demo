# ══════════════════════════════════════════════════════════
#  Hammond Dental AI Receptionist — Environment Variables
#  Copy this file to .env.local for local dev (git-ignored).
#  Set all of these in Vercel → Project → Settings → Environment Variables.
#  NEVER commit .env.local or real credentials to git.
# ══════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose to frontend

# ─── SMS via TextBelt ──────────────────────────────────────────────────────────
# textbelt.com — no account needed for testing
# "textbelt"  = free tier (1 SMS/day total, good for local testing)
# Real key    = buy at textbelt.com (~$10 for 50 credits, 1 credit = 1 SMS)
TEXTBELT_API_KEY=textbelt

# ─── Staff phone numbers ───────────────────────────────────────────────────────
DOCTOR_EMERGENCY_PHONE=+17025550001    # Receives 🚨 emergency SMS (Feature 2)
FRONT_DESK_PHONE=+17025550002          # Receives morning summary at 8am (Feature 3)

# ─── Vapi ──────────────────────────────────────────────────────────────────────
VAPI_AGENT_ID=54da6a88-1e1e-4977-a216-1670b689a253

# REST API key — Vapi dashboard → API Keys (used by scripts/vapi-setup.js)
VAPI_API_KEY=your_vapi_api_key_here

# Shared secret between Vapi tool calls and your webhook endpoints.
# Generate any random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAPI_WEBHOOK_SECRET=your_random_secret_here

# Vercel domain used by the setup script to rewrite tool URLs
# e.g. dental-demo-vn2d.vercel.app  (no https://)
VERCEL_DOMAIN=your_project.vercel.app

# ─── Dashboard auth (Feature 5) ────────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_strong_password
JWT_SECRET=generate_with_node_crypto_randomBytes_32

# ─── Vercel Cron (Feature 3) ───────────────────────────────────────────────────
# Vercel sets CRON_SECRET automatically in production.
# For local testing: set to any string and pass as Authorization: Bearer <value>
CRON_SECRET=vercel_sets_this_automatically_in_prod

# ─── Timezone (Las Vegas) ──────────────────────────────────────────────────────
TIMEZONE=America/Los_Angeles
